data/

# ── macOS junk ────────────────────────────────────────────────────────────────
.DS_Store

# ── IDE files ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log